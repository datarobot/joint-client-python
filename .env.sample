# Copy this file to .env and replace placeholders.
# DataRobot credentials are required only for hosted JointFM inference.
DATAROBOT_ENDPOINT=https://app.datarobot.com/api/v2
DATAROBOT_API_TOKEN=

# JointFM compatibility metadata for the selected deployment.
JOINTFM_SCHEMA_VERSION=v1
# Optional drift-detection pin; the SDK discovers the model version from /healthz when unset:
# JOINTFM_MODEL_VERSION=jointfm-inference:0.2.0+ckpt.fin-2026-05-22

# Choose exactly one deployment selector.
# 1. Deployment ID: SDK builds the hosted predictionsUnstructured URL.
# JOINTFM_DEPLOYMENT_ID=

# 2. Deployment URL: SDK appends predictionsUnstructured.
# JOINTFM_DEPLOYMENT_URL=https://app.datarobot.com/api/v2/deployments/<deployment-id>

# 3. Full hosted prediction URL.
# JOINTFM_PREDICT_URL=https://app.datarobot.com/api/v2/deployments/<deployment-id>/predictionsUnstructured

# 4. Named Pulumi target resolved from saved outputs JSON.
# The JSON file must map target names to Pulumi stack outputs, for example:
# {"fin-studentt": {"deployment_id": "<deployment-id>"}}
# JOINTFM_DEPLOYMENT_TARGET=fin-studentt
# JOINTFM_PULUMI_OUTPUTS_PATH=./jointfm-pulumi-outputs.json

# 5. Direct local REST service started with `task service:start` in joint.
# Local service calls use GET /healthz and POST /predict without DataRobot auth.
# JOINTFM_LOCAL_BASE_URL=http://127.0.0.1:8080